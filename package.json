{
  "name": "lie-hard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:staging": "npx env-cmd -f .env.staging next dev",
    "build": "next build",
    "build:staging": "npx env-cmd -f .env.staging next build",
    "build:production": "npx env-cmd -f .env.production next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "rm -rf .next out",
    "deploy:prod": "npm run clean && firebase use prod && npm run build:production && firebase deploy",
    "deploy:staging": "npm run clean && firebase use staging && npm run build:staging && firebase deploy",
    "deploy:rules:prod": "firebase use prod && firebase deploy --only firestore:rules",
    "deploy:rules:staging": "firebase use staging && firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "@types/papaparse": "^5.3.16",
    "firebase": "^12.1.0",
    "next": "^14.2.31",
    "papaparse": "^5.5.3",
    "react": "18",
    "react-dom": "18"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "env-cmd": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5"
  }
}
